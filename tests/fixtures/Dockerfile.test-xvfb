# Test image for `tests/test_display_integration.py`. Build once with:
#
#   docker build -t vexis-test-xvfb:latest -f tests/fixtures/Dockerfile.test-xvfb .
#
# Then run the integration test:
#
#   pytest -m display_real tests/test_display_integration.py
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
    xvfb \
    x11-utils \
    && rm -rf /var/lib/apt/lists/*
CMD ["sleep", "infinity"]
