# Bot token issued by @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Numeric Telegram user ID allowed to talk to this bot (single-user auth)
TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id-here

# Working directory Claude Code runs in (visible, no dot — you may seed files here)
VEXIS_WORKSPACE=~/vexis-workspace

# Root logger level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
